@{
    Layout = null;
}
@model List<WMS.Terminal.Models.ExpectedShipment>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Ожидаемые поставки - ТСД Автопитер</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f5f5f5;
            padding: 20px;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: -20px -20px 20px -20px;
            padding: 20px;
            color: white;
        }

        .back-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            color: white;
            margin-bottom: 10px;
            cursor: pointer;
        }

        .shipment-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .invoice {
            font-size: 18px;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
        }

        .product {
            font-size: 16px;
            color: #667eea;
            margin-bottom: 5px;
        }

        .qty {
            margin: 10px 0;
        }

        .progress-bar {
            background: #e0e0e0;
            border-radius: 20px;
            height: 20px;
            overflow: hidden;
            margin: 10px 0;
        }

        .progress-fill {
            background: #4caf50;
            height: 100%;
            border-radius: 20px;
            transition: width 0.3s;
        }

        .status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
        }

            .status.Pending {
                background: #ffc107;
                color: #333;
            }

            .status.Partial {
                background: #17a2b8;
                color: white;
            }

            .status.Completed {
                background: #28a745;
                color: white;
            }

        .date {
            color: #999;
            font-size: 12px;
            margin-top: 10px;
        }

        .empty {
            text-align: center;
            padding: 50px;
            color: #999;
            background: white;
            border-radius: 16px;
        }
    </style>
</head>
<body>
    <div class="header">
        <button class="back-btn" onclick="location.href='/Terminal/MainMenu'">← Назад</button>
        <h1>🚚 Ожидаемые поставки</h1>
    </div>

    @if (Model.Any())
    {
        foreach (var shipment in Model)
        {
            var receivedPercent = shipment.ReceivedQuantity * 100 / shipment.ExpectedQuantity;
            <div class="shipment-card">
                <div class="invoice">📄 Накладная: @shipment.InvoiceNumber</div>
                <div class="product">📦 @shipment.Product?.Name (@shipment.Product?.Sku)</div>
                <div class="qty">
                    Ожидается: <strong>@shipment.ExpectedQuantity шт</strong><br>
                    Принято: <strong>@shipment.ReceivedQuantity шт</strong>
                </div>
                <div class="progress-bar">
                    <div class="progress-fill" style="width: @receivedPercent%"></div>
                </div>
                <div>
                    <span class="status @shipment.Status">
                        @(shipment.Status == "Pending" ? "Ожидается" :
                            shipment.Status == "Partial" ? "Частично" : "Завершена")
                    </span>
                </div>
                <div class="date">📅 Ожидаемая дата: @shipment.ExpectedDate.ToString("dd.MM.yyyy")</div>
            </div>
        }
    }
    else
    {
        <div class="empty">
            📭 Нет ожидаемых поставок
        </div>
    }

    <div style="margin-top: 20px;">
        <button class="back-btn" style="background: #667eea;" onclick="location.href='/Terminal/MainMenu'">🏠 Главное меню</button>
    </div>
</body>
</html>