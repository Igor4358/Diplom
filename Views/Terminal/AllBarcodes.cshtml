@{
    Layout = null;
}
@model WMS.Terminal.Models.BarcodeViewModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Штрих-коды склада - ТСД Автопитер</title>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f5f5f5;
            padding: 20px;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: -20px -20px 20px -20px;
            padding: 20px;
            color: white;
        }

        .back-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            color: white;
            margin-bottom: 10px;
            cursor: pointer;
        }

        h1 {
            font-size: 24px;
        }

        .barcode-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }

        .barcode-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .barcode-label {
            font-size: 14px;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
        }

        .barcode-image {
            width: 100%;
            max-width: 250px;
            height: auto;
        }

        .barcode-code {
            font-size: 12px;
            color: #999;
            margin-top: 8px;
            font-family: monospace;
        }

        .print-btn {
            background: #28a745;
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
            margin: 20px 0;
            width: 100%;
        }

            .print-btn:active {
                transform: scale(0.98);
            }

        .section-title {
            margin: 20px 0 15px 0;
            font-size: 18px;
            color: #333;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .empty {
            text-align: center;
            padding: 30px;
            color: #999;
        }

        @@media print {
            body {
                background: white;
                padding: 10px;
            }

            .header {
                margin: -10px -10px 10px -10px;
                padding: 15px;
            }

            .back-btn, .print-btn {
                display: none;
            }

            .barcode-card {
                break-inside: avoid;
                box-shadow: none;
                border: 1px solid #ddd;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <button class="back-btn" onclick="location.href='/Terminal/MainMenu'">← Назад</button>
        <h1>🏷️ Штрих-коды склада</h1>
    </div>

    <button class="print-btn" onclick="window.print()">🖨️ Печать штрих-кодов</button>

    <!-- ============================================ -->
    <!--  БЛОК ТОВАРОВ (исправленный)                 -->
    <!-- ============================================ -->
    <div class="section-title">📦 Товары на складе</div>
    @if (Model.Products.Any())
    {
        <div class="barcode-grid">
            @foreach (var item in Model.Products)
            {
                <div class="barcode-card">
                    <div class="barcode-label">@item.Name</div>
                    <!-- Используем уникальный штрих-код товара на складе -->
                    <svg id="barcode-@item.Barcode" class="barcode-image"></svg>
                    <div class="barcode-code">Артикул: @item.Sku</div>
                    <div class="barcode-code" style="font-size: 10px; color: #667eea;">
                        Штрих-код: @item.Barcode
                    </div>
                    <div style="font-size: 12px; color: #4caf50;">📍 @item.CellAddress</div>
                    <script>
                        try {
                            JsBarcode("#barcode-@item.Barcode", "@item.Barcode", {
                                format: "EAN13",
                                width: 2,
                                height: 80,
                                displayValue: true,
                                fontSize: 14,
                                margin: 10
                            });
                        } catch(e) { console.log('Ошибка:', e); }
                    </script>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty">📭 Нет товаров на складе</div>
    }

    <div class="section-title">📍 Ячейки склада</div>
    @if (Model.Cells.Any())
    {
        <div class="barcode-grid">
            @foreach (var cell in Model.Cells)
            {
                <div class="barcode-card">
                    <div class="barcode-label">Ячейка @cell.Address</div>
                    <svg id="barcode-cell-@cell.Address" class="barcode-image"></svg>
                    <div class="barcode-code">Адрес: @cell.Address</div>
                    <div style="font-size: 12px; color: @(cell.IsOccupied ? "#4caf50" : "#ff9800");">
                        @(cell.IsOccupied ? "📦 Есть товар" : "🟡 Пустая")
                    </div>
                    <script>
                        try {
                            JsBarcode("#barcode-cell-@cell.Address", "@cell.Address", {
                                format: "CODE128",
                                width: 2,
                                height: 80,
                                displayValue: true,
                                fontSize: 14,
                                margin: 10
                            });
                        } catch(e) { console.log('Ошибка:', e); }
                    </script>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty">📭 Нет ячеек на складе</div>
    }
</body>
</html>