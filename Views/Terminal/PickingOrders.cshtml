@{
    Layout = null;
}
@model IEnumerable<dynamic>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Сбор заказов - ТСД Автопитер</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f5f5f5;
            padding: 20px;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: -20px -20px 20px -20px;
            padding: 20px;
            color: white;
        }

        .back-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            color: white;
            margin-bottom: 10px;
            cursor: pointer;
        }

        .order-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 15px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            cursor: pointer;
        }

        .order-number {
            font-size: 20px;
            font-weight: bold;
            color: #333;
        }

        .order-items {
            color: #666;
            margin-top: 8px;
            font-size: 14px;
        }

        .empty {
            text-align: center;
            padding: 50px;
            color: #999;
        }
    </style>
</head>
<body>
    <div class="header">
        <button class="back-btn" onclick="location.href='/Terminal/MainMenu'">← Назад</button>
        <h1>📦 Сбор заказов</h1>
    </div>

    @if (Model != null && Model.Any())
    {
        foreach (var order in Model)
        {
            <div class="order-card" onclick="location.href='/Terminal/StartPicking?orderId=@order.OrderId'">
                <div class="order-number">Заказ № @order.OrderNumber</div>
                <div class="order-items">Позиций к сборке: @order.Items.Count</div>
            </div>
        }
    }
    else
    {
        <div class="empty">
            📭 Нет заказов для сборки<br>
            <small>(Сначала создайте заказ в базе данных)</small>
        </div>
    }
</body>
</html>