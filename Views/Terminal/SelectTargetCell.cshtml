@model List<WMS.Terminal.Models.Cell>

@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Выбор ячейки - ТСД Автопитер</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 500px;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            text-align: center;
            margin-bottom: 20px;
        }

        h2 {
            color: #333;
            margin-bottom: 10px;
        }

        .info {
            background: #f0f0f0;
            padding: 15px;
            border-radius: 16px;
            margin: 15px 0;
            text-align: left;
        }

        .info-row {
            padding: 5px 0;
        }

        .cell-list {
            margin: 20px 0;
            max-height: 400px;
            overflow-y: auto;
        }

        .cell-btn {
            display: block;
            width: 100%;
            padding: 15px;
            margin: 8px 0;
            background: #f8f9fa;
            border: 2px solid #ddd;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
            text-align: center;
            cursor: pointer;
        }

            .cell-btn:active {
                background: #e0e0e0;
                transform: scale(0.98);
            }

            .cell-btn.selected {
                background: #667eea;
                color: white;
                border-color: #667eea;
            }

        .qty-input {
            width: 100%;
            padding: 15px;
            font-size: 18px;
            text-align: center;
            border: 2px solid #ddd;
            border-radius: 12px;
            margin: 15px 0;
        }

        .submit-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-size: 18px;
            cursor: pointer;
            width: 100%;
        }

        .back-btn {
            background: #999;
            color: white;
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-size: 18px;
            cursor: pointer;
            width: 100%;
            margin-top: 10px;
        }

        .error {
            background: #fee;
            color: #c33;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2>🔄 Куда переместить?</h2>

            <div class="info">
                <div class="info-row"><strong>📦 Товар:</strong> @ViewBag.ProductName</div>
                <div class="info-row"><strong>📍 Текущая ячейка:</strong> @ViewBag.CurrentCell</div>
                <div class="info-row"><strong>📊 Доступно:</strong> <span style="color:#667eea; font-size:20px;">@ViewBag.Quantity шт</span></div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="error">❌ @ViewBag.Error</div>
            }

            <form method="post" asp-action="ConfirmMove">
                <input type="hidden" name="targetCellId" id="selectedCellId" value="">

                <div class="cell-list">
                    <div style="margin-bottom: 10px; color: #666;">Выберите целевую ячейку:</div>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var cell in Model)
                        {
                            <button type="button" class="cell-btn" data-cell-id="@cell.Id" data-cell-addr="@cell.Address">
                                📦 @cell.Address
                            </button>
                        }
                    }
                    else
                    {
                        <div style="text-align: center; padding: 20px; color: #999;">
                            ⚠️ Нет доступных ячеек для перемещения
                        </div>
                    }
                </div>

                <input type="number" name="moveQuantity" id="quantity" class="qty-input"
                       placeholder="Количество для перемещения" value="@ViewBag.Quantity"
                       min="1" max="@ViewBag.Quantity">

                <button type="submit" class="submit-btn" id="submitBtn" disabled>✅ Подтвердить перемещение</button>
            </form>

            <button class="back-btn" onclick="location.href='/Terminal/Sorting'">← Назад</button>
        </div>
    </div>

    <script>
        let selectedCellId = null;

        document.querySelectorAll('.cell-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.cell-btn').forEach(b => b.classList.remove('selected'));
                this.classList.add('selected');
                selectedCellId = this.getAttribute('data-cell-id');
                document.getElementById('selectedCellId').value = selectedCellId;
                document.getElementById('submitBtn').disabled = false;
            });
        });

        // Ограничиваем количество максимумом
        const qtyInput = document.getElementById('quantity');
        const maxQty = @ViewBag.Quantity;
        qtyInput.addEventListener('change', function() {
            if (parseInt(this.value) > maxQty) this.value = maxQty;
            if (parseInt(this.value) < 1) this.value = 1;
        });
    </script>
</body>
</html>