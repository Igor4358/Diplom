@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Подтверждение добавления - ТСД Автопитер</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            max-width: 480px;
            width: 100%;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        h2 {
            color: #333;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #666;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .product-info {
            background: #f0f0f0;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

            .product-info .label {
                color: #666;
                font-size: 12px;
            }

            .product-info .value {
                font-size: 20px;
                font-weight: bold;
                color: #333;
            }

            .product-info .sku {
                font-size: 14px;
                color: #999;
                margin-top: 5px;
            }

        .quantity-input {
            width: 100%;
            padding: 20px;
            font-size: 24px;
            text-align: center;
            border: 2px solid #ddd;
            border-radius: 12px;
            margin: 20px 0;
        }

            .quantity-input:focus {
                outline: none;
                border-color: #667eea;
            }

        .btn-primary {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            cursor: pointer;
            margin-top: 10px;
        }

        .btn-secondary {
            width: 100%;
            padding: 14px;
            background: #999;
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            cursor: pointer;
            margin-top: 10px;
        }

            .btn-primary:active, .btn-secondary:active {
                transform: scale(0.98);
            }

        .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

            .numpad button {
                background: #f0f0f0;
                color: #333;
                border: none;
                border-radius: 12px;
                padding: 16px;
                font-size: 24px;
                cursor: pointer;
            }

                .numpad button:active {
                    background: #ddd;
                }

        .cell-address {
            margin-top: 15px;
            font-size: 14px;
            color: #667eea;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2>✅ Товар уже есть на складе</h2>
            <div class="subtitle">Увеличьте количество товара в существующей ячейке</div>

            <div class="product-info">
                <div class="label">Товар</div>
                <div class="value">@ViewBag.ProductName</div>
                <div class="sku">Артикул: @ViewBag.ProductSku</div>
                <div class="cell-address">📍 Ячейка: @ViewBag.CellAddress</div>
            </div>

            <form method="post" id="confirmForm">
                <input type="number" name="confirmQuantity" id="quantity" class="quantity-input" value="1" min="1">
                <button type="submit" class="btn-primary">✅ Добавить @ViewBag.Quantity шт</button>
            </form>

            <div class="numpad">
                <button type="button" onclick="addDigit('1')">1</button>
                <button type="button" onclick="addDigit('2')">2</button>
                <button type="button" onclick="addDigit('3')">3</button>
                <button type="button" onclick="addDigit('4')">4</button>
                <button type="button" onclick="addDigit('5')">5</button>
                <button type="button" onclick="addDigit('6')">6</button>
                <button type="button" onclick="addDigit('7')">7</button>
                <button type="button" onclick="addDigit('8')">8</button>
                <button type="button" onclick="addDigit('9')">9</button>
                <button type="button" onclick="clearDigit()">⌫</button>
                <button type="button" onclick="addDigit('0')">0</button>
                <button type="button" onclick="submitForm()">✓</button>
            </div>

            <button class="btn-secondary" onclick="location.href='/Terminal/Receiving'">← Назад</button>
        </div>
    </div>

    <script>
        const input = document.getElementById('quantity');
        function addDigit(d) {
            if (input.value === '0') input.value = d;
            else input.value = input.value + d;
        }
        function clearDigit() {
            input.value = input.value.slice(0, -1) || '0';
        }
        function submitForm() {
            document.getElementById('confirmForm').submit();
        }
    </script>
</body>
</html>