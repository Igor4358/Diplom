@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Приёмка товара - ТСД Автопитер</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 500px;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            text-align: center;
        }

        h2 {
            color: #333;
            margin-bottom: 20px;
        }

        .success {
            background: #d4edda;
            color: #155724;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .error {
            background: #fee;
            color: #c33;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        input {
            width: 100%;
            padding: 20px;
            font-size: 24px;
            text-align: center;
            border: 2px solid #ddd;
            border-radius: 12px;
            margin: 20px 0;
        }

        button {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            cursor: pointer;
        }

        .back-btn {
            background: #999;
            margin-top: 10px;
        }

        .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

            .numpad button {
                background: #f0f0f0;
                color: #333;
                font-size: 24px;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2>📥 Приёмка товара</h2>

            @if (TempData["Success"] != null)
            {
                <div class="success">✅ @TempData["Success"]</div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="error">❌ @ViewBag.Error</div>
            }

            <form method="post">
                <input type="text" name="scannedSku" id="scannedSku" placeholder="Отсканируйте штрих-код" autofocus>
                <button type="submit">Далее</button>
            </form>

            <button class="back-btn" onclick="location.href='/Terminal/MainMenu'">← Главное меню</button>
        </div>
    </div>
    <script>
        document.getElementById('scannedSku')?.focus();
    </script>
</body>
</html>