@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no">
    <title>Подтверждение - ТСД Автопитер</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 500px;
            margin: 0 auto;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 30px;
            text-align: center;
        }

        h2 {
            color: #333;
            margin-bottom: 20px;
        }

        .product {
            background: #f0f0f0;
            padding: 20px;
            border-radius: 16px;
            margin: 20px 0;
        }

        .value {
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }

        input {
            width: 100%;
            padding: 20px;
            font-size: 24px;
            text-align: center;
            border: 2px solid #ddd;
            border-radius: 12px;
            margin: 20px 0;
        }

        button {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 18px;
            cursor: pointer;
        }

        .error {
            background: #fee;
            color: #c33;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

            .numpad button {
                background: #f0f0f0;
                color: #333;
                font-size: 24px;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2>✅ Подтвердите количество</h2>

            <div class="product">
                <div class="value">@ViewBag.ProductName</div>
                <div style="margin-top:15px">Требуется: <strong>@ViewBag.RequiredQty шт</strong></div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="error">❌ @ViewBag.Error</div>
            }

            <form method="post" id="confirmForm">
                <input type="hidden" name="taskId" value="@ViewBag.TaskId">
                <input type="number" name="pickedQuantity" id="quantity" value="@ViewBag.RequiredQty" min="1" autofocus>
                <button type="submit">Подтвердить сборку</button>
            </form>

            <div class="numpad">
                <button type="button" onclick="addDigit('1')">1</button>
                <button type="button" onclick="addDigit('2')">2</button>
                <button type="button" onclick="addDigit('3')">3</button>
                <button type="button" onclick="addDigit('4')">4</button>
                <button type="button" onclick="addDigit('5')">5</button>
                <button type="button" onclick="addDigit('6')">6</button>
                <button type="button" onclick="addDigit('7')">7</button>
                <button type="button" onclick="addDigit('8')">8</button>
                <button type="button" onclick="addDigit('9')">9</button>
                <button type="button" onclick="clearDigit()">⌫</button>
                <button type="button" onclick="addDigit('0')">0</button>
                <button type="button" onclick="submitForm()">✓</button>
            </div>
        </div>
    </div>
    <script>
        const input = document.getElementById('quantity');
        function addDigit(d) {
            if (input.value === '0') input.value = d;
            else input.value = input.value + d;
        }
        function clearDigit() {
            input.value = input.value.slice(0, -1) || '0';
        }
        function submitForm() {
            document.getElementById('confirmForm').submit();
        }
    </script>
</body>
</html>